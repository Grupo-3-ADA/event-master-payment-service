# Normaliza line endings para LF no repositório
* text=auto eol=lf

# Código fonte Java
*.java text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf

# Binários — não tocar em line endings
*.jar  binary
*.war  binary
*.class binary
*.png  binary
*.jpg  binary
*.pdf  binary

      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"clienteId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"moeda\": \"BRL\",\n  \"metodoPagamento\": \"PIX\"\n}"
      }
    },

    {

      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"pedidoId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"clienteId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"valor\": 100.00,\n  \"moeda\": \"USD\",\n  \"metodoPagamento\": \"BOLETO\"\n}"
      }
    },

    {
      "_id": "req_boleto_confirmacao",
      "_type": "request",
      "parentId": "grp_boleto",
      "name": "Webhook — Confirmar pagamento do boleto",
      "method": "POST",
      "url": "{{ _.base_url }}/webhooks/boleto/confirmacao",
      "description": "Simula callback do gateway após pagamento. Substitua pagamentoId pelo id retornado em 'Boleto — Gerado'. Esperado: 200 OK. Depois consulte o pagamento: status APROVADO.",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"pagamentoId\": \"00000000-0000-0000-0000-000000000000\",\n  \"dataPagamento\": \"2026-05-20\",\n  \"valorPago\": 250.00\n}"
      }
    },

    {
      "_id": "req_boleto_buscar",
      "_type": "request",
      "parentId": "grp_boleto",
      "name": "Boleto — Consultar por ID",
      "method": "GET",
      "url": "{{ _.base_url }}/pagamentos/00000000-0000-0000-0000-000000000000",
      "description": "Substitua o UUID pelo id retornado em 'Boleto — Gerado'. Esperado: 200 OK com linhaDigitavel e dataVencimento",
      "headers": [],
      "body": { "mimeType": "application/json" }
    },


      "description": "Substitua o UUID pelo id retornado em algum POST anterior. Esperado: 200 OK",
      "headers": [],
      "body": { "mimeType": "application/json" }
    },

    {
      "_id": "req_idempotencia",
      "_type": "request",
      "parentId": "grp_erros",
      "name": "Idempotência — pedidoId duplicado (409)",
      "method": "POST",
      "url": "{{ _.base_url }}/pagamentos",
      "description": "Mesmo pedidoId do request 'PIX Aprovado'. Esperado: 409 Conflict com pagamentoId do original",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"pedidoId\": \"11111111-1111-1111-1111-111111111111\",\n  \"clienteId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"valor\": 150.00,\n  \"moeda\": \"BRL\",\n  \"metodoPagamento\": \"PIX\"\n}"
      }
    },

    {
      "_id": "req_validacao",
      "_type": "request",
      "parentId": "grp_erros",
      "name": "Validação de entrada — campos ausentes (400)",
      "method": "POST",
      "url": "{{ _.base_url }}/pagamentos",
      "description": "Sem pedidoId e sem valor. Esperado: 400 Bad Request com mensagem de erro",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
